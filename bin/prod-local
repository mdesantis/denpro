#!/bin/bash

set -euo pipefail

export PORT="${PORT:-3000}"
export RAILS_ENV=production
export NODE_ENV=production

VITE_DISABLE_SRI="${VITE_DISABLE_SRI:-}" npx vite build
VITE_DISABLE_SRI="${VITE_DISABLE_SRI:-}" npx vite build --ssr

if command -v overmind 1> /dev/null 2>&1
then
  overmind start -f Procfile.prod-local -s ./tmp/.overmind.sock "$@"
  exit $?
fi

if command -v hivemind 1> /dev/null 2>&1
then
  echo "Hivemind is installed. Running the application with Hivemind..."
  exec hivemind Procfile.prod-local "$@"
  exit $?
fi

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

foreman start -f Procfile.prod-local "$@"
