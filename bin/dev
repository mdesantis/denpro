#!/usr/bin/env sh

export PORT="${PORT:-3000}"

# Pre-build SSR bundle so ssr-deno railtie finds it at boot
npx vite build --ssr app/frontend/entrypoints/ssr.jsx --outDir dist/server --logLevel warn

if command -v overmind 1> /dev/null 2>&1
then
  overmind start -f Procfile.dev "$@"
  exit $?
fi

if command -v hivemind 1> /dev/null 2>&1
then
  echo "Hivemind is installed. Running the application with Hivemind..."
  exec hivemind Procfile.dev "$@"
  exit $?
fi

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

foreman start -f Procfile.dev "$@"
